# SkyNetControl environment configuration
#
# Copy to `.env` and fill in. Every setting maps to a `SKYNET_*` env var
# (Pydantic Settings with env_prefix=SKYNET_).
#
# For runtime configuration that lives in the database (net address, PAT
# mailbox path, Claude API key, delivery backends, etc.), see
# docs/deployment/app-config-keys.md — those are set via the in-app
# /config page after first login.

# ---------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------

# JWT signing key. Generate with: openssl rand -hex 32
SKYNET_JWT_SECRET_KEY=change-me-with-openssl-rand-hex-32

# Public base URL the app is reachable at.
# Local dev: use http://localhost:5173 so OAuth callbacks land on Vite
# (which proxies /api/* to the backend on :8000). The cookie set on the
# callback response then binds to :5173 where the SPA can use it.
# Production: your real https URL.
SKYNET_APP_BASE_URL=http://localhost:5173

# ---------------------------------------------------------------------
# At least one auth provider must be enabled
# ---------------------------------------------------------------------
#
# Full provider-by-provider setup recipes (callback URLs, scopes,
# screenshots-equivalent steps) live in:
#   docs/deployment/oidc-providers.md
#
# TL;DR: each fixed provider needs three env vars (note the DOUBLE underscore
# between the provider name and the field — required so pydantic-settings can
# parse field names that themselves contain underscores like CLIENT_ID):
#   SKYNET_AUTH_<PROVIDER>__ENABLED=true
#   SKYNET_AUTH_<PROVIDER>__CLIENT_ID=...
#   SKYNET_AUTH_<PROVIDER>__CLIENT_SECRET=...
#
# Callback URL pattern:
#   {SKYNET_APP_BASE_URL}/api/auth/callback/{provider}
#
# Local dev tip: GitHub is the easiest path — no domain verification
# or app review.

SKYNET_AUTH_GITHUB__ENABLED=false
SKYNET_AUTH_GITHUB__CLIENT_ID=
SKYNET_AUTH_GITHUB__CLIENT_SECRET=

SKYNET_AUTH_GOOGLE__ENABLED=false
SKYNET_AUTH_GOOGLE__CLIENT_ID=
SKYNET_AUTH_GOOGLE__CLIENT_SECRET=

SKYNET_AUTH_MICROSOFT__ENABLED=false
SKYNET_AUTH_MICROSOFT__CLIENT_ID=
SKYNET_AUTH_MICROSOFT__CLIENT_SECRET=

SKYNET_AUTH_DISCORD__ENABLED=false
SKYNET_AUTH_DISCORD__CLIENT_ID=
SKYNET_AUTH_DISCORD__CLIENT_SECRET=

SKYNET_AUTH_FACEBOOK__ENABLED=false
SKYNET_AUTH_FACEBOOK__CLIENT_ID=
SKYNET_AUTH_FACEBOOK__CLIENT_SECRET=

# Dynamic OIDC providers (e.g. Authentik, Keycloak, Zitadel) use a single
# underscore between the slug and each field — they are parsed by a custom
# regex, not by pydantic-settings nesting:
#   SKYNET_AUTH_OIDC_<SLUG>_ENABLED=true
#   SKYNET_AUTH_OIDC_<SLUG>_NAME=...
#   SKYNET_AUTH_OIDC_<SLUG>_CLIENT_ID=...
#   SKYNET_AUTH_OIDC_<SLUG>_CLIENT_SECRET=...
#   SKYNET_AUTH_OIDC_<SLUG>_ISSUER_URL=...
# SKYNET_AUTH_OIDC_AUTHENTIK_ENABLED=false
# SKYNET_AUTH_OIDC_AUTHENTIK_NAME=Authentik
# SKYNET_AUTH_OIDC_AUTHENTIK_CLIENT_ID=
# SKYNET_AUTH_OIDC_AUTHENTIK_CLIENT_SECRET=
# SKYNET_AUTH_OIDC_AUTHENTIK_ISSUER_URL=

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------

# Defaults to a local SQLite file. Use PostgreSQL for multi-user / shared
# deployments: postgresql+psycopg://user:pass@host/dbname
SKYNET_DATABASE_URL=sqlite:///skynetcontrol.db

# ---------------------------------------------------------------------
# JWT (defaults are fine for most setups)
# ---------------------------------------------------------------------

# SKYNET_JWT_ALGORITHM=HS256
# SKYNET_JWT_EXPIRE_MINUTES=1440  # 24 hours

# ---------------------------------------------------------------------
# SMTP (optional — enables the EmailBackend for reminder/roster delivery)
# ---------------------------------------------------------------------

# If SKYNET_SMTP__HOST is not set, email delivery is silently disabled.
# Note the DOUBLE underscore between SMTP and each field.
# SKYNET_SMTP__HOST=smtp.example.com
# SKYNET_SMTP__PORT=587
# SKYNET_SMTP__USERNAME=
# SKYNET_SMTP__PASSWORD=
# SKYNET_SMTP__USE_TLS=true
# SKYNET_SMTP__FROM_ADDRESS=net@example.com

# ---------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------

# SKYNET_DEBUG=false
# SKYNET_STATIC_DIR=frontend/dist  # production: serves the built SPA
