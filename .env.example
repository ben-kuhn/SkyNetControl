# SkyNetControl environment configuration
#
# Copy to `.env` and fill in. Every setting maps to a `SKYNET_*` env var
# (Pydantic Settings with env_prefix=SKYNET_).
#
# For runtime configuration that lives in the database (net address, PAT
# mailbox path, Claude API key, delivery backends, etc.), see
# docs/deployment/app-config-keys.md — those are set via the in-app
# /config page after first login.

# ---------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------

# JWT signing key. Generate with: openssl rand -hex 32
SKYNET_JWT_SECRET_KEY=change-me-with-openssl-rand-hex-32

# Public base URL the app is reachable at.
# Local dev: use http://localhost:5173 so OAuth callbacks land on Vite
# (which proxies /api/* to the backend on :8000). The cookie set on the
# callback response then binds to :5173 where the SPA can use it.
# Production: your real https URL.
SKYNET_APP_BASE_URL=http://localhost:5173

# ---------------------------------------------------------------------
# At least one auth provider must be enabled
# ---------------------------------------------------------------------
#
# Each provider needs:
#   SKYNET_AUTH_<PROVIDER>_ENABLED=true
#   SKYNET_AUTH_<PROVIDER>_CLIENT_ID=...
#   SKYNET_AUTH_<PROVIDER>_CLIENT_SECRET=...
#
# Register an OAuth app with the provider; set the callback URL to:
#   {SKYNET_APP_BASE_URL}/api/auth/callback/{provider}
# e.g. http://localhost:5173/api/auth/callback/github
#
# Local dev tip: GitHub is the easiest — no domain verification or app
# review. Settings → Developer settings → OAuth Apps → New OAuth App.

SKYNET_AUTH_GITHUB_ENABLED=false
SKYNET_AUTH_GITHUB_CLIENT_ID=
SKYNET_AUTH_GITHUB_CLIENT_SECRET=

SKYNET_AUTH_GOOGLE_ENABLED=false
SKYNET_AUTH_GOOGLE_CLIENT_ID=
SKYNET_AUTH_GOOGLE_CLIENT_SECRET=

SKYNET_AUTH_MICROSOFT_ENABLED=false
SKYNET_AUTH_MICROSOFT_CLIENT_ID=
SKYNET_AUTH_MICROSOFT_CLIENT_SECRET=

SKYNET_AUTH_DISCORD_ENABLED=false
SKYNET_AUTH_DISCORD_CLIENT_ID=
SKYNET_AUTH_DISCORD_CLIENT_SECRET=

SKYNET_AUTH_FACEBOOK_ENABLED=false
SKYNET_AUTH_FACEBOOK_CLIENT_ID=
SKYNET_AUTH_FACEBOOK_CLIENT_SECRET=

# Generic OIDC provider (e.g. Authentik, Keycloak, Zitadel)
SKYNET_AUTH_OIDC_ENABLED=false
SKYNET_AUTH_OIDC_CLIENT_ID=
SKYNET_AUTH_OIDC_CLIENT_SECRET=
SKYNET_AUTH_OIDC_ISSUER_URL=

# ---------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------

# Defaults to a local SQLite file. Use PostgreSQL for multi-user / shared
# deployments: postgresql+psycopg://user:pass@host/dbname
SKYNET_DATABASE_URL=sqlite:///skynetcontrol.db

# ---------------------------------------------------------------------
# JWT (defaults are fine for most setups)
# ---------------------------------------------------------------------

# SKYNET_JWT_ALGORITHM=HS256
# SKYNET_JWT_EXPIRE_MINUTES=1440  # 24 hours

# ---------------------------------------------------------------------
# SMTP (optional — enables the EmailBackend for reminder/roster delivery)
# ---------------------------------------------------------------------

# If SKYNET_SMTP_HOST is not set, email delivery is silently disabled.
# SKYNET_SMTP_HOST=smtp.example.com
# SKYNET_SMTP_PORT=587
# SKYNET_SMTP_USERNAME=
# SKYNET_SMTP_PASSWORD=
# SKYNET_SMTP_USE_TLS=true
# SKYNET_SMTP_FROM_ADDRESS=net@example.com

# ---------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------

# SKYNET_DEBUG=false
# SKYNET_STATIC_DIR=frontend/dist  # production: serves the built SPA
